<UserControl x:Class="sqlSense.UI.MenueItems.Settings.Pages.GeneralSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../SettingsResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <StackPanel Margin="0,0,0,0">
        <TextBlock Text="General" Style="{StaticResource SectionHeader}"/>

        <StackPanel Margin="0,0,0,18">
            <CheckBox Content="Restore previous session on startup" 
                      Style="{StaticResource SettingCheckBox}" IsChecked="True"/>
            <TextBlock Text="Automatically reopen workbooks from your last session." 
                       Style="{StaticResource SettingDescription}" Margin="24,4,0,0"/>
        </StackPanel>

        <StackPanel Margin="0,0,0,18">
            <CheckBox Content="Check for updates automatically" 
                      Style="{StaticResource SettingCheckBox}" IsChecked="True"/>
            <TextBlock Text="Periodically check for new versions of SQLSense." 
                       Style="{StaticResource SettingDescription}" Margin="24,4,0,0"/>
        </StackPanel>

        <StackPanel Margin="0,0,0,18">
            <CheckBox Content="Enable telemetry" 
                      Style="{StaticResource SettingCheckBox}"/>
            <TextBlock Text="Send anonymous usage data to help improve SQLSense." 
                       Style="{StaticResource SettingDescription}" Margin="24,4,0,0"/>
        </StackPanel>

        <Border Height="1" Background="#3C3C3C" Margin="0,8,0,24"/>

        <TextBlock Text="Auto Save" Style="{StaticResource SectionHeader}"/>

        <StackPanel Margin="0,0,0,18">
            <CheckBox Content="Auto-save workbooks" 
                      Style="{StaticResource SettingCheckBox}" IsChecked="True"/>
            <TextBlock Text="Automatically save workbooks after changes." 
                       Style="{StaticResource SettingDescription}" Margin="24,4,0,0"/>
        </StackPanel>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Auto-save delay (seconds):" Style="{StaticResource SettingLabel}"/>
            <TextBox Grid.Column="1" Text="30" Style="{StaticResource SettingTextBox}"/>
        </Grid>
    </StackPanel>
</UserControl>
