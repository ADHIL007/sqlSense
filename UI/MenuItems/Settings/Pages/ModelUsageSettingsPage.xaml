<UserControl x:Class="sqlSense.UI.MenueItems.Settings.Pages.ModelUsageSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../SettingsResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- DataGrid Styles matching app theme -->
            <Style x:Key="UsageDataGridStyle" TargetType="DataGrid">
                <Setter Property="Background" Value="#1E1E1E"/>
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="RowBackground" Value="Transparent"/>
                <Setter Property="AlternatingRowBackground" Value="Transparent"/>
                <Setter Property="GridLinesVisibility" Value="All"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#3C3C3C"/>
                <Setter Property="VerticalGridLinesBrush" Value="#3C3C3C"/>
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="CanUserResizeColumns" Value="True"/>
                <Setter Property="CanUserReorderColumns" Value="False"/>
                <Setter Property="SelectionMode" Value="Single"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="AutoGenerateColumns" Value="False"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="CanUserSortColumns" Value="True"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
            </Style>

            <Style x:Key="UsageColumnHeaderStyle" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#1E1E1E"/>
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Padding" Value="14,12"/>
                <Setter Property="BorderBrush" Value="#3C3C3C"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridColumnHeader">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                    <TextBlock Text=" ⇅" Foreground="#3A3F4B" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="UsageCellStyle" TargetType="DataGridCell">
                <Setter Property="Padding" Value="14,10"/>
                <Setter Property="BorderThickness" Value="0,0,1,0"/>
                <Setter Property="BorderBrush" Value="#3C3C3C"/>
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="DataGridCell">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#094771"/>
                        <Setter Property="Foreground" Value="White"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="UsageRowStyle" TargetType="DataGridRow">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="MinHeight" Value="42"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#2A2D2E"/>
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#094771"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Small icon button for filter/export area -->
            <Style x:Key="ToolButton" TargetType="Button">
                <Setter Property="Background" Value="#252526"/>
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="BorderBrush" Value="#3C3C3C"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#2A2D2E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Pagination button style -->
            <Style x:Key="PageButton" TargetType="Button">
                <Setter Property="Width" Value="30"/>
                <Setter Property="Height" Value="30"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#CCCCCC"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Margin" Value="2,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bd" Property="Background" Value="#2A2D2E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Active page button -->
            <Style x:Key="PageButtonActive" TargetType="Button" BasedOn="{StaticResource PageButton}">
                <Setter Property="Background" Value="#094771"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header Row ═══ -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Model Usage" FontSize="20" FontWeight="SemiBold" Foreground="White" FontFamily="Segoe UI"/>
                <TextBlock Text="Track usage and token count for each model." Foreground="#888888" FontSize="12" Margin="0,4,0,0" FontFamily="Segoe UI"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock x:Name="TbLastUpdated" Text="Last updated: –" Foreground="#888888" FontSize="11" VerticalAlignment="Center" Margin="0,0,14,0"/>
                <Button Click="Refresh_Click" Style="{StaticResource ToolButton}" Padding="10,6" ToolTip="Refresh">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Refresh" FontSize="11.5" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══ Summary Cards ═══ -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,18">

            <!-- Total Requests -->
            <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="0,0,6,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Background="#1E3A5F" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0">
                            <TextBlock Text="&#xE8B0;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#60A5FA" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Total Requests" Foreground="#6B7280" FontSize="11.5" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="TbTotalRequests" Text="0" Foreground="White" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                    <TextBlock Text="All models" Foreground="#374151" FontSize="10.5" FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- Total Prompt Tokens -->
            <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="3,0,3,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Background="#3B1D6E" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0">
                            <TextBlock Text="&#xE8C1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#C084FC" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Total Prompt Tokens" Foreground="#6B7280" FontSize="11.5" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="TbTotalPromptTokens" Text="0" Foreground="White" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                    <TextBlock Text="All models" Foreground="#374151" FontSize="10.5" FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- Total Completion Tokens -->
            <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="3,0,3,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Background="#14532D" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0">
                            <TextBlock Text="&#xE8C1;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#4ADE80" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Total Completion Tokens" Foreground="#6B7280" FontSize="11.5" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="TbTotalCompletionTokens" Text="0" Foreground="White" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                    <TextBlock Text="All models" Foreground="#374151" FontSize="10.5" FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

            <!-- Total Tokens -->
            <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="10" Padding="16,14" Margin="6,0,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Border Background="#7C2D12" CornerRadius="8" Width="32" Height="32" Margin="0,0,10,0">
                            <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#FB923C" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Total Tokens" Foreground="#6B7280" FontSize="11.5" FontFamily="Segoe UI"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="TbTotalTokens" Text="0" Foreground="White" FontSize="26" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                    <TextBlock Text="All models" Foreground="#374151" FontSize="10.5" FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- ═══ Filter / Export Row ═══ -->
        <Grid Grid.Row="2" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Time Range Filter -->
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Border Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="6" Padding="4,0,0,0" Height="32">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center" Margin="6,0,4,0"/>
                        <ComboBox x:Name="CmbTimeRange" Width="120" Style="{StaticResource SettingComboBox}" 
                                  SelectionChanged="TimeRange_Changed" SelectedIndex="2"
                                  Background="Transparent" BorderThickness="0" Height="30">
                            <ComboBoxItem Content="Today" Style="{StaticResource SettingComboBoxItem}"/>
                            <ComboBoxItem Content="Last 24 hours" Style="{StaticResource SettingComboBoxItem}"/>
                            <ComboBoxItem Content="Last 7 days" Style="{StaticResource SettingComboBoxItem}"/>
                            <ComboBoxItem Content="Last 30 days" Style="{StaticResource SettingComboBoxItem}"/>
                            <ComboBoxItem Content="All time" Style="{StaticResource SettingComboBoxItem}"/>
                        </ComboBox>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Export Button -->
            <Button Grid.Column="2" Click="Export_Click" Style="{StaticResource ToolButton}" Padding="10,6" Margin="8,0,0,0" ToolTip="Export as CSV">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE896;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="Export" FontSize="11.5" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- ═══ Usage Table ═══ -->
        <Border Grid.Row="3" Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1" CornerRadius="10" 
                ClipToBounds="True" Margin="0,12,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="UsageGrid" 
                          Style="{StaticResource UsageDataGridStyle}"
                          ColumnHeaderStyle="{StaticResource UsageColumnHeaderStyle}"
                          CellStyle="{StaticResource UsageCellStyle}"
                          RowStyle="{StaticResource UsageRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Model" Binding="{Binding Model}" Width="*" MinWidth="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#E5E7EB"/>
                                    <Setter Property="FontWeight" Value="Medium"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Provider" Binding="{Binding Provider}" Width="130">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#9CA3AF"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Requests" Binding="{Binding Requests, StringFormat={}{0:N0}}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#D1D5DB"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Prompt Tokens" Binding="{Binding PromptTokens, StringFormat={}{0:N0}}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#D1D5DB"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Completion Tokens" Binding="{Binding CompletionTokens, StringFormat={}{0:N0}}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#D1D5DB"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Total Tokens" Binding="{Binding TotalTokens, StringFormat={}{0:N0}}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Last Used" Binding="{Binding LastUsedDisplay}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="#6B7280"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Total (All Models) summary row -->
                <Border Grid.Row="1" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Padding="14,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="130"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0" Padding="0,0,14,0" Margin="-14,-10,0,-10">
                            <TextBlock Text="Total (All Models)" Foreground="White" FontWeight="Bold" FontSize="12.5" VerticalAlignment="Center" Margin="14,0,0,0"/>
                        </Border>
                        <Border Grid.Column="1" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0" Padding="14,0" Margin="0,-10,0,-10">
                            <TextBlock Text="" Foreground="#6B7280" FontSize="12.5" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="2" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0" Padding="14,0" Margin="0,-10,0,-10">
                            <TextBlock x:Name="TbTotalRowRequests" Text="0" Foreground="White" FontWeight="Bold" FontSize="12.5" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="3" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0" Padding="14,0" Margin="0,-10,0,-10">
                            <TextBlock x:Name="TbTotalRowPrompt" Text="0" Foreground="White" FontWeight="Bold" FontSize="12.5" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="4" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0" Padding="14,0" Margin="0,-10,0,-10">
                            <TextBlock x:Name="TbTotalRowCompletion" Text="0" Foreground="White" FontWeight="Bold" FontSize="12.5" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="5" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0" Padding="14,0" Margin="0,-10,0,-10">
                            <TextBlock x:Name="TbTotalRowTokens" Text="0" Foreground="White" FontWeight="Bold" FontSize="12.5" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Border>
                        <Border Grid.Column="6" Padding="14,0" Margin="0,-10,-14,-10">
                            <TextBlock Text="–" Foreground="#4B5563" FontSize="12.5" TextAlignment="Right" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Pagination Footer -->
                <Border Grid.Row="2" Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="0,1,0,0" Padding="14,8">
                    <Grid>
                        <TextBlock x:Name="TbShowingInfo" Text="Showing 0 models" Foreground="#4B5563" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Left" FontFamily="Segoe UI"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="«" Style="{StaticResource PageButton}" Click="PageFirst_Click"/>
                            <Button Content="‹" Style="{StaticResource PageButton}" Click="PagePrev_Click"/>
                            <Button x:Name="BtnPage1" Content="1" Style="{StaticResource PageButtonActive}"/>
                            <Button x:Name="BtnPage2" Content="2" Style="{StaticResource PageButton}" Visibility="Collapsed" Click="PageNum_Click"/>
                            <Button x:Name="BtnPage3" Content="3" Style="{StaticResource PageButton}" Visibility="Collapsed" Click="PageNum_Click"/>
                            <Button Content="›" Style="{StaticResource PageButton}" Click="PageNext_Click"/>
                            <Button Content="»" Style="{StaticResource PageButton}" Click="PageLast_Click"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock Text="Rows per page:" Foreground="#4B5563" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox x:Name="CmbRowsPerPage" Width="55" Style="{StaticResource SettingComboBox}" 
                                      Height="26" FontSize="11" SelectedIndex="0" SelectionChanged="RowsPerPage_Changed">
                                <ComboBoxItem Content="8" Style="{StaticResource SettingComboBoxItem}"/>
                                <ComboBoxItem Content="15" Style="{StaticResource SettingComboBoxItem}"/>
                                <ComboBoxItem Content="25" Style="{StaticResource SettingComboBoxItem}"/>
                                <ComboBoxItem Content="50" Style="{StaticResource SettingComboBoxItem}"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Border>

        <!-- ═══ Bottom Actions ═══ -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,10,0,0">
            <Button Click="ClearData_Click" Style="{StaticResource ToolButton}" Padding="12,6" 
                    Background="#1F1215" BorderBrush="#2D1A1E">
                <TextBlock Text="Clear Usage Data" Foreground="#F87171" FontSize="11.5"/>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
