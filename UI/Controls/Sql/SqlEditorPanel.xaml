<UserControl x:Class="sqlSense.UI.Controls.Sql.SqlEditorPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:sci="clr-namespace:ScintillaNET.WPF;assembly=ScintillaNET.WPF"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="800">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ═══ Results Pane DataGrid ═══ -->
        <Style x:Key="ResultsDataGridStyle" TargetType="DataGrid">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="#1E1E1E"/>
            <Setter Property="AlternatingRowBackground" Value="#252526"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2D2D2D"/>
            <Setter Property="VerticalGridLinesBrush" Value="#3C3C3C"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HeadersVisibility" Value="All"/>
            <Setter Property="AutoGenerateColumns" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="RowHeight" Value="24"/>
            <Setter Property="SelectionMode" Value="Extended"/>
            <Setter Property="SelectionUnit" Value="CellOrRowHeader"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
            <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
        </Style>

        <!-- ═══ DataGrid Column Header ═══ -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="26"/>
        </Style>

        <!-- ═══ DataGrid Row ═══ -->
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D4D4D4"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2D2E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══ DataGrid Cell ═══ -->
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="6,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#094771"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ═══ DataGrid Row Header ═══ -->
        <Style TargetType="DataGridRowHeader">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRowHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=DataGridRow}, 
                                       Path=(ItemsControl.AlternationIndex)}"
                                       Foreground="#858585" FontFamily="Consolas" FontSize="10"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Margin="0,0,6,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Results Tab Style ═══ -->
        <Style x:Key="ResultsTabControlStyle" TargetType="TabControl">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="ResultsTabItemStyle" TargetType="TabItem">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="#9D9D9D"/>
            <Setter Property="BorderBrush" Value="#3C3C3C"/>
            <Setter Property="BorderThickness" Value="1,0,1,0"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="0,0,1,0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource BorderBrush}"
                                BorderThickness="1,0,1,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1E1E1E"/>
                                <Setter TargetName="bd" Property="BorderThickness" Value="1,2,1,0"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="#383838"/>
                                <Setter Property="Foreground" Value="#CCCCCC"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <!-- splitter -->
            <RowDefinition Height="Auto"/>
            <!-- results pane - collapsed when no results -->
            <RowDefinition>
                <RowDefinition.Style>
                    <Style TargetType="RowDefinition">
                        <Setter Property="Height" Value="0"/>
                        <Setter Property="MinHeight" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SqlEditor.HasResults}" Value="True">
                                <Setter Property="Height" Value="260"/>
                                <Setter Property="MinHeight" Value="120"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </RowDefinition.Style>
            </RowDefinition>
        </Grid.RowDefinitions>

        <!-- ═══ Row 0: Scintilla SQL Editor ═══ -->
        <Border Grid.Row="0" Background="#1E1E1E" BorderThickness="0" ClipToBounds="True">
            <sci:ScintillaWPF x:Name="SqlEditor"/>
        </Border>

        <!-- ═══ Row 1: Drag Splitter ═══ -->
        <GridSplitter Grid.Row="1"
                      x:Name="ResultsSplitter"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="#2D2D30"
                      Cursor="SizeNS"
                      ShowsPreview="True"
                      Visibility="{Binding SqlEditor.HasResults, Converter={StaticResource BoolToVis}}">
            <!-- Grab handle indicator -->
            <GridSplitter.Template>
                <ControlTemplate TargetType="GridSplitter">
                    <Border Background="#2D2D30" BorderBrush="#3C3C3C" BorderThickness="0,1,0,1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Orientation="Horizontal" Margin="0,1">
                            <Rectangle Width="40" Height="2" Fill="#555555" RadiusX="1" RadiusY="1"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </GridSplitter.Template>
        </GridSplitter>

        <!-- ═══ Row 2: Results & Messages Panel ═══ -->
        <Border Grid.Row="2"
                Background="#1E1E1E"
                BorderBrush="#3C3C3C"
                BorderThickness="0,1,0,0"
                Visibility="{Binding SqlEditor.HasResults, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TabControl Style="{StaticResource ResultsTabControlStyle}"
                            SelectedIndex="{Binding SqlEditor.SelectedTabIndex}"
                            Background="#1E1E1E">
                    <TabControl.Template>
                        <ControlTemplate TargetType="TabControl">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Tab Header Strip -->
                                <Border Grid.Row="0" Background="#2D2D30"
                                        BorderBrush="#3C3C3C" BorderThickness="0,0,0,1">
                                    <DockPanel>
                                        <TabPanel DockPanel.Dock="Left"
                                                  IsItemsHost="True"
                                                  Background="Transparent"/>
                                        <!-- X close button right-aligned -->
                                        <Button DockPanel.Dock="Right"
                                                Background="Transparent" BorderThickness="0"
                                                Width="26" Height="26" Margin="0,0,4,0"
                                                Cursor="Hand" ToolTip="Close Results Pane"
                                                Command="{Binding DataContext.SqlEditor.HideResultsCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}">
                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="10" Foreground="#888888"
                                                       VerticalAlignment="Center"/>
                                        </Button>
                                        <Border/>
                                    </DockPanel>
                                </Border>

                                <!-- Tab Content -->
                                <Border Grid.Row="1" Background="#1E1E1E">
                                    <ContentPresenter ContentSource="SelectedContent"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </TabControl.Template>

                    <!-- ─── Results Tab ─── -->
                    <TabItem Style="{StaticResource ResultsTabItemStyle}">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8B3;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" VerticalAlignment="Center"
                                           Margin="0,0,6,0" Foreground="#4FC3F7"/>
                                <TextBlock Text="Results" FontSize="11" VerticalAlignment="Center"/>
                                <!-- row count badge -->
                                <Border Background="#094771" CornerRadius="8"
                                        Padding="6,1" Margin="8,0,0,0"
                                        Visibility="{Binding DataContext.SqlEditor.HasResults,
                                                     RelativeSource={RelativeSource AncestorType=UserControl},
                                                     Converter={StaticResource BoolToVis}}">
                                    <TextBlock FontFamily="Consolas" FontSize="9"
                                               Foreground="#87CEEB" VerticalAlignment="Center">
                                        <Run Text="{Binding DataContext.SqlEditor.QueryRowCount,
                                             RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                                        <Run Text=" rows"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </TabItem.Header>
                        <TabItem.Content>
                            <DataGrid Style="{StaticResource ResultsDataGridStyle}"
                                      ItemsSource="{Binding SqlEditor.QueryResultsView}"
                                      AlternationCount="2"
                                      Margin="0" BorderThickness="0"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </TabItem.Content>
                    </TabItem>

                    <!-- ─── Messages Tab ─── -->
                    <TabItem Style="{StaticResource ResultsTabItemStyle}">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets"
                                           FontSize="11" VerticalAlignment="Center"
                                           Margin="0,0,6,0" Foreground="#4FC3F7"/>
                                <TextBlock Text="Messages" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </TabItem.Header>
                        <TabItem.Content>
                            <TextBox Text="{Binding SqlEditor.QueryMessages, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="NoWrap"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Background="#1E1E1E"
                                     Foreground="#D4D4D4"
                                     CaretBrush="#AEAFAD"
                                     BorderThickness="0"
                                     Padding="12,8"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"/>
                        </TabItem.Content>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
