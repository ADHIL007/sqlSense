<UserControl x:Class="sqlSense.UI.Controls.Ai.AiChatInterface"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:md="clr-namespace:Markdig.Wpf;assembly=Markdig.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="300">
    <UserControl.Resources>
        <ResourceDictionary>
            <!-- ══════════════════════════════════════════════════════════════ -->
            <!--  MARKDIG.WPF — DARK THEME OVERRIDES                          -->
            <!-- ══════════════════════════════════════════════════════════════ -->

            <!-- FlowDocument base -->
            <Style TargetType="{x:Type FlowDocument}" x:Key="{x:Static md:Styles.DocumentStyleKey}">
                <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                <Setter Property="PagePadding" Value="0"/>
                <Setter Property="TextAlignment" Value="Left"/>
                <Setter Property="Typography.StandardLigatures" Value="True"/>
            </Style>

            <!-- ── Paragraph ────────────────────────────────────────────── -->
            <Style TargetType="{x:Type Paragraph}">
                <Setter Property="Margin" Value="0,4,0,4"/>
            </Style>

            <!-- ── Headings ─────────────────────────────────────────────── -->
            <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static md:Styles.Heading1StyleKey}">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
                <Setter Property="FontWeight" Value="Bold"/>
                <Setter Property="Margin" Value="0,8,0,4"/>
            </Style>
            <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static md:Styles.Heading2StyleKey}">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,6,0,4"/>
            </Style>
            <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static md:Styles.Heading3StyleKey}">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin" Value="0,6,0,4"/>
            </Style>
            <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static md:Styles.Heading4StyleKey}">
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Margin" Value="0,6,0,4"/>
            </Style>
            <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static md:Styles.Heading5StyleKey}">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Margin" Value="0,4,0,2"/>
            </Style>
            <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static md:Styles.Heading6StyleKey}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Margin" Value="0,4,0,2"/>
            </Style>

            <!-- ── Code ─────────────────────────────────────────────────── -->
            <!-- Fenced / indented code blocks -->
            <!-- Enhanced Code Block Style -->
            <Style TargetType="{x:Type Paragraph}" x:Key="{x:Static md:Styles.CodeBlockStyleKey}">

                <!-- Typography -->
                <Setter Property="FontFamily" Value="Cascadia Code, Consolas"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="LineHeight" Value="18"/>

                <!-- Colors -->
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="Background" Value="{DynamicResource BackgroundBrush}"/>

                <!-- Spacing -->
                <Setter Property="Padding" Value="14,12,14,12"/>
                <Setter Property="Margin" Value="0,10,0,10"/>

                <!-- Border for depth -->
                <Setter Property="BorderBrush" Value="{DynamicResource PanelLightBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>

                <!-- Rounded feel (if container supports it) -->
                <Setter Property="TextElement.Foreground" Value="#D4D4D4"/>

            </Style>
            <!-- Inline `code` -->
            <Style TargetType="{x:Type Run}" x:Key="{x:Static md:Styles.CodeStyleKey}">
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
                <Setter Property="Background" Value="{DynamicResource PanelLightBrush}"/>
            </Style>

            <!-- ── Blockquote ───────────────────────────────────────────── -->
            <Style TargetType="{x:Type Section}" x:Key="{x:Static md:Styles.QuoteBlockStyleKey}">
                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryAccentBrush}"/>
                <Setter Property="BorderThickness" Value="3,0,0,0"/>
                <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
                <Setter Property="Padding" Value="14,4,0,4"/>
                <Setter Property="Margin" Value="0,6,0,6"/>
            </Style>

            <!-- ── Tables ───────────────────────────────────────────────── -->
            <Style TargetType="{x:Type Table}" x:Key="{x:Static md:Styles.TableStyleKey}">
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="CellSpacing" Value="0"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            </Style>
            <Style TargetType="{x:Type TableCell}" x:Key="{x:Static md:Styles.TableCellStyleKey}">
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1,1,0,0"/>
                <Setter Property="Padding" Value="8,4,8,4"/>
            </Style>
            <Style TargetType="{x:Type TableRow}" x:Key="{x:Static md:Styles.TableHeaderStyleKey}">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
                <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
            </Style>

            <!-- ── Hyperlinks ───────────────────────────────────────────── -->
            <Style TargetType="{x:Type Hyperlink}" x:Key="{x:Static md:Styles.HyperlinkStyleKey}">
                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
                <Setter Property="TextDecorations" Value="{x:Null}"/>
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Foreground" Value="#81D4FA"/>
                        <Setter Property="TextDecorations" Value="Underline"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ── Lists ────────────────────────────────────────────────── -->
            <Style TargetType="{x:Type List}">
                <Setter Property="Margin" Value="20,4,0,4"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            </Style>

            <!-- ── Thematic Break (hr) ──────────────────────────────────── -->
            <Style TargetType="{x:Type Line}" x:Key="{x:Static md:Styles.ThematicBreakStyleKey}">
                <Setter Property="Stretch" Value="Fill"/>
                <Setter Property="Stroke" Value="{DynamicResource BorderBrush}"/>
            </Style>

            <!-- ── Task List Checkbox ───────────────────────────────────── -->
            <Style TargetType="{x:Type CheckBox}" x:Key="{x:Static md:Styles.TaskListStyleKey}">
                <Setter Property="Margin" Value="0,0,4,-2"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryAccentBrush}"/>
            </Style>

            <!-- ── Inline decorations ───────────────────────────────────── -->
            <Style TargetType="{x:Type Span}" x:Key="{x:Static md:Styles.MarkedStyleKey}">
                <Setter Property="Background" Value="#404CAF50"/>
                <Setter Property="Foreground" Value="#4CAF50"/>
            </Style>
            <Style TargetType="{x:Type Span}" x:Key="{x:Static md:Styles.StrikeThroughStyleKey}">
                <Setter Property="TextBlock.TextDecorations" Value="Strikethrough"/>
                <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
            </Style>
            <Style TargetType="{x:Type Span}" x:Key="{x:Static md:Styles.InsertedStyleKey}">
                <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
            </Style>
            <Style TargetType="{x:Type Span}" x:Key="{x:Static md:Styles.SubscriptStyleKey}">
                <Setter Property="Typography.Variants" Value="Subscript"/>
            </Style>
            <Style TargetType="{x:Type Span}" x:Key="{x:Static md:Styles.SuperscriptStyleKey}">
                <Setter Property="Typography.Variants" Value="Superscript"/>
            </Style>

            <!-- ── Image ────────────────────────────────────────────────── -->
            <Style TargetType="{x:Type Image}" x:Key="{x:Static md:Styles.ImageStyleKey}">
                <Setter Property="MaxHeight" Value="{Binding RelativeSource={RelativeSource Self}, Path=Source.(BitmapSource.PixelHeight)}"/>
                <Setter Property="MaxWidth" Value="{Binding RelativeSource={RelativeSource Self}, Path=Source.(BitmapSource.PixelWidth)}"/>
            </Style>

            <!-- ── MarkdownViewer Template ──────────────────────────────── -->
            <Style TargetType="md:MarkdownViewer">
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="md:MarkdownViewer">
                            <FlowDocumentScrollViewer Document="{TemplateBinding Document}"
                                ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                IsSelectionEnabled="True"
                                Padding="0" Margin="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Focusable="True" />
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ══════════════════════════════════════════════════════════════ -->
            <!--  APP UI STYLES                                                -->
            <!-- ══════════════════════════════════════════════════════════════ -->

            <Style x:Key="PopupItemButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="#2A2D2E"/>
                                </Trigger>
                                <Trigger Property="Tag" Value="Selected">
                                    <Setter TargetName="bg" Property="Background" Value="#172635"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Modern Sleek ScrollBar Style -->
            <Style TargetType="{x:Type ScrollBar}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Width" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <Grid x:Name="Bg" Background="Transparent">
                                <Track x:Name="PART_Track" IsDirectionReversed="true">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" Focusable="False"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb>
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="{x:Type Thumb}">
                                                    <Border x:Name="thumbBorder" Background="#333333" CornerRadius="4" Margin="2,0,10,10"/>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="thumbBorder" Property="Background" Value="#555555"/>
                                                        </Trigger>
                                                        <Trigger Property="IsDragging" Value="True">
                                                            <Setter TargetName="thumbBorder" Property="Background" Value="#888888"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" Focusable="False"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Width" Value="Auto"/>
                        <Setter Property="Height" Value="8"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type ScrollBar}">
                                    <Grid Background="Transparent">
                                        <Track x:Name="PART_Track">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="{x:Static ScrollBar.PageLeftCommand}" Opacity="0" Focusable="False"/>
                                            </Track.DecreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb>
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="{x:Type Thumb}">
                                                            <Border x:Name="thumbBorder" Background="#333333" CornerRadius="4" Margin="0,2,0,0"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="thumbBorder" Property="Background" Value="#555555"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="{x:Static ScrollBar.PageRightCommand}" Opacity="0" Focusable="False"/>
                                            </Track.IncreaseRepeatButton>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Background="{DynamicResource BackgroundBrush}">
        <!-- Chat UI (expanded state) -->
        <Grid x:Name="ChatUI" Background="{DynamicResource BackgroundBrush}" Visibility="Visible" TextElement.FontFamily="Segoe UI Emoji, Segoe UI">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,5">
                <TextBlock Text="Agent" Foreground="{DynamicResource PrimaryAccentBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="16,8,0,8" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,16,0">
                    <Button x:Name="NewChatBtn" Style="{StaticResource PopupItemButton}" Padding="4" ToolTip="New Chat" Click="NewChatBtn_Click">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                    <Button x:Name="HistoryBtn" Style="{StaticResource PopupItemButton}" Padding="4" ToolTip="Chat History" Click="HistoryBtn_Click">
                        <TextBlock Text="&#xE81C;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                    <Button x:Name="MoreOptionsBtn" Style="{StaticResource PopupItemButton}" Padding="4" ToolTip="More Options" Click="MoreOptionsBtn_Click">
                        <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                    <Button x:Name="ExpandBtn"
                        Style="{StaticResource PopupItemButton}"
                        Padding="4"
                        ToolTip="Expand / Collapse"
                        Click="ExpandBtn_Click">
                        <TextBlock Text="&#xE740;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                    <Button x:Name="CloseBtn" Style="{StaticResource PopupItemButton}" Padding="4" ToolTip="Close" Command="{Binding DataContext.ToggleAiChatCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Chat Area -->
            <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,0,16,0" Padding="0,0,16,0" PanningMode="VerticalFirst">
                <StackPanel x:Name="ChatMessagesPanel" Margin="0,16,0,16">
                    <!-- Dynamic chat messages go here -->
                </StackPanel>
            </ScrollViewer>

            <!-- History Overlay -->
            <Grid x:Name="HistoryOverlay" Grid.Row="1" Grid.RowSpan="2" Background="{DynamicResource BackgroundBrush}" Visibility="Collapsed" Panel.ZIndex="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Select a conversation" Foreground="{DynamicResource MutedBrush}" FontSize="13" Margin="16,16,16,8"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,0,16,16">
                    <StackPanel x:Name="HistoryListPanel">
                    </StackPanel>
                </ScrollViewer>
            </Grid>
            <!-- Input Area -->
            <Border Grid.Row="2" Background="#08FFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="10" Margin="16,5,16,16">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsKeyboardFocusWithin, RelativeSource={RelativeSource Self}}" Value="True">
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                                <Setter Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#3B82F6" BlurRadius="15" ShadowDepth="0" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <RichTextBox x:Name="InputTextBox" 
                                     Background="Transparent" 
                                     Foreground="{DynamicResource TextPrimaryBrush}" 
                                     FontFamily="Segoe UI Emoji, Segoe UI"
                                     BorderThickness="0" 
                                     Padding="12,8,12,8" 
                                     MinHeight="50"
                                     MaxHeight="200" 
                                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                                     FontSize="13"
                                     VerticalScrollBarVisibility="Auto"
                                     AcceptsReturn="True"
                                     PreviewKeyDown="InputTextBox_PreviewKeyDown"
                                     TextChanged="InputTextBox_TextChanged"
                                     Typography.StandardLigatures="True">
                            <FlowDocument LineHeight="20">
                                <Paragraph Margin="0">
                                    <Run Text=""/>
                                </Paragraph>
                            </FlowDocument>
                        </RichTextBox>
                        <TextBlock x:Name="WatermarkText" Text="Ask anything, @ to mention" FontFamily="Segoe UI Emoji, Segoe UI" FontSize="13" LineHeight="20" Foreground="{DynamicResource MutedBrush}" Margin="16,8,0,0" VerticalAlignment="Top" IsHitTestVisible="False" TextTrimming="CharacterEllipsis"/>
                    </Grid>

                    <Grid Grid.Row="1" Margin="8,0,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- Plus Button -->
                            <Button Background="Transparent" Foreground="#888888" BorderThickness="0" Cursor="Hand" Margin="0,0,4,0" ToolTip="Add Context" Padding="4">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
                            </Button>

                            <!-- Fast Toggle -->
                            <Button x:Name="FastModeToggleBtn" Background="Transparent" Foreground="#888888" BorderThickness="0" Cursor="Hand" Margin="0,0,4,0" ToolTip="Toggle Fast Mode" Click="FastModeToggleBtn_Click" Padding="4,4,8,4">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="FastModeText" Text="Fast" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Model Selector -->
                            <Button x:Name="ModelSelectorBtn" Background="Transparent" Foreground="#888888" BorderThickness="0" Cursor="Hand" ToolTip="Select Model" Padding="4,4,8,4" Click="ModelSelectorBtn_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock x:Name="CurrentModelLabel" Text="" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Send Button -->
                        <Button x:Name="SendBtn" Grid.Column="2" 
                                Background="{DynamicResource PrimaryAccentBrush}" 
                                Foreground="Black" 
                                BorderThickness="0" 
                                Width="28" 
                                Height="28" 
                                Cursor="Hand"
                                Click="SendButton_Click" VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="14">
                                        <TextBlock x:Name="icon" Text="&#xE72A;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12" Margin="1,0,0,0"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource SuccessBrush}"/>
                                        </Trigger>
                                        <Trigger Property="Tag" Value="Stop">
                                            <Setter TargetName="bg" Property="CornerRadius" Value="6"/>
                                            <Setter TargetName="icon" Property="Text" Value="&#xE15B;"/>
                                            <Setter TargetName="icon" Property="Foreground" Value="White"/>
                                            <Setter TargetName="bg" Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                            <Setter TargetName="icon" Property="Margin" Value="0"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <Border x:Name="DisconnectedOverlay" Grid.Row="0" Grid.RowSpan="2" Background="#EE1A1A1A" CornerRadius="10" Visibility="Collapsed" Panel.ZIndex="10">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Please connect to an AI provider in Settings" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                            <Button Content="Open Settings" Background="#333333" Foreground="#E0E0E0" BorderThickness="0" Padding="12,6" Cursor="Hand" Click="OpenSettings_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="6"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <!-- Custom Popups matching Cursor style -->
        <Popup x:Name="ModePopup" StaysOpen="False" PlacementTarget="{Binding ElementName=FastModeToggleBtn}" Placement="Top" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="-8">
            <Border Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="6" Width="360" Effect="{StaticResource NodeShadow}">
                <StackPanel>
                    <TextBlock Text="Conversation mode" Foreground="#AAAAAA" FontSize="11" Margin="8,4,8,8"/>

                    <Button x:Name="ModeReasonBtn" Style="{StaticResource PopupItemButton}" Click="ModeReasonBtn_Click">
                        <StackPanel>
                            <TextBlock Text="Reason" FontSize="13" FontWeight="SemiBold" Foreground="#E0E0E0" Margin="0,0,0,4"/>
                            <TextBlock Text="Agent can reason before executing tasks. Use for deep research, complex tasks, or collaborative work" FontSize="11" Foreground="#999999" TextWrapping="Wrap" LineHeight="16"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="ModeFastBtn" Style="{StaticResource PopupItemButton}" Click="ModeFastBtn_Click">
                        <StackPanel>
                            <TextBlock Text="Fast" FontSize="13" FontWeight="SemiBold" Foreground="#E0E0E0" Margin="0,0,0,4"/>
                            <TextBlock Text="Agent will execute tasks directly. Use for simple tasks that can be completed faster" FontSize="11" Foreground="#999999" TextWrapping="Wrap" LineHeight="16"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>

        <Popup x:Name="ModelPopup" StaysOpen="False" PlacementTarget="{Binding ElementName=ModelSelectorBtn}" Placement="Top" AllowsTransparency="True" PopupAnimation="Fade" VerticalOffset="-8">
            <Border Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="6" MinWidth="220" Effect="{StaticResource NodeShadow}">
                <StackPanel>
                    <TextBlock Text="Model" Foreground="#AAAAAA" FontSize="11" Margin="8,4,8,8"/>
                    <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ModelListPanel"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
