<UserControl x:Class="sqlSense.UI.Controls.CreateTableCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="420" d:DesignWidth="460">

    <UserControl.Resources>
        <!-- Reuse identical styles from TablePreviewCard for full theme parity -->
        <Style x:Key="SmallIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2D2E"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card form input TextBox style -->
        <Style x:Key="CardTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>

        <!-- Action button style -->
        <Style x:Key="CardActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3E3E42"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#094771"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary accent button -->
        <Style x:Key="CardPrimaryBtn" TargetType="Button" BasedOn="{StaticResource CardActionBtn}">
            <Setter Property="Background" Value="{StaticResource PrimaryAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Circle outline button (matches table preview card join buttons) -->
        <Style x:Key="CircleOutlineBtn" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryAccentBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse x:Name="circle" 
                                     Stroke="{StaticResource PrimaryAccentBrush}" 
                                     StrokeThickness="1.5" 
                                     Fill="Transparent"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="0,-1,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="circle" Property="Fill" Value="{StaticResource PrimaryAccentBrush}"/>
                                <Setter Property="Foreground" Value="#1E1E1E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="circle" Property="Fill" Value="White"/>
                                <Setter Property="Foreground" Value="#1E1E1E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark ComboBox style for the DataGrid editing cell -->
        <Style x:Key="DarkEditComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="IsDropDownOpen" Value="True"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#252526"/>
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                        <Setter Property="Padding" Value="6,3"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#094771"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#094771"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource PanelBrush}" 
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
            MinWidth="440" MaxWidth="500"
            Effect="{StaticResource NodeShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Form fields -->
                <RowDefinition Height="*"/>     <!-- Columns grid -->
                <RowDefinition Height="Auto"/>  <!-- Footer -->
            </Grid.RowDefinitions>

            <!-- ═══ Card Header (matches TablePreviewCard header) ═══ -->
            <Border Grid.Row="0" Background="#2D2D30" Padding="12,8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="13" 
                                   Foreground="#4FC3F7" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Create New Table" FontSize="12" 
                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                   VerticalAlignment="Center" FontWeight="SemiBold"/>
                    </StackPanel>

                    <Button Grid.Column="1" Style="{StaticResource SmallIconBtn}" 
                            Click="CloseCard_Click" ToolTip="Cancel">
                        <TextBlock Text="✕" FontSize="11" FontFamily="Segoe UI"/>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ Form Fields ═══ -->
            <StackPanel Grid.Row="1" Margin="12,10,12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TABLE NAME" FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}" 
                                   FontFamily="Segoe UI" Margin="0,0,0,4"/>
                        <TextBox x:Name="TableNameTxt" Style="{StaticResource CardTextBox}" 
                                 Text="" GotFocus="TextBox_GotFocus"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="SCHEMA" FontSize="9" FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}" 
                                   FontFamily="Segoe UI" Margin="0,0,0,4"/>
                        <TextBox x:Name="SchemaNameTxt" Style="{StaticResource CardTextBox}" 
                                 Text="dbo" GotFocus="TextBox_GotFocus"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- ═══ Columns DataGrid ═══ -->
            <Border Grid.Row="2" Margin="12,4,12,4" BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1" Background="#1E1E1E">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Section header -->
                    <Border Grid.Row="0" Background="#2D2D30" Padding="8,5"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <TextBlock Text="COLUMNS" FontSize="9" FontWeight="SemiBold"
                                       Foreground="{StaticResource MutedBrush}" 
                                       FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Style="{StaticResource CircleOutlineBtn}" Click="AddColumn_Click" 
                                        ToolTip="Add Column" Width="20" Height="20">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                </Button>
                                <Button Style="{StaticResource CircleOutlineBtn}" Click="RemoveColumn_Click" 
                                        ToolTip="Remove Selected" Width="20" Height="20" Margin="4,0,0,0">
                                    <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" x:Name="ColumnsGrid" 
                              AutoGenerateColumns="False"
                              Background="Transparent" 
                              Foreground="{StaticResource TextSecondaryBrush}"
                              BorderThickness="0"
                              GridLinesVisibility="None"
                              RowBackground="#252526" 
                              AlternatingRowBackground="#2D2D30"
                              HeadersVisibility="Column"
                              FontSize="11" FontFamily="Consolas"
                              RowHeight="28"
                              CanUserAddRows="False" 
                              CanUserDeleteRows="False"
                              CanUserResizeRows="False"
                              SelectionMode="Single" 
                              SelectionUnit="FullRow"
                              MaxHeight="200"
                              ColumnWidth="*"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="130"/>
                            <DataGridComboBoxColumn x:Name="TypeCol" Header="Type" Width="110"
                                SelectedItemBinding="{Binding DataType}"
                                EditingElementStyle="{StaticResource DarkEditComboBox}"/>
                            <DataGridTextColumn Header="Len" Binding="{Binding Length}" Width="55"/>
                            <DataGridCheckBoxColumn Header="Null" Binding="{Binding IsNullable}" Width="50"/>
                            <DataGridCheckBoxColumn Header="PK" Binding="{Binding IsPrimaryKey}" Width="40"/>
                            <DataGridCheckBoxColumn Header="A.I" Binding="{Binding IsAutoIncrement}" Width="40">
                               
                            </DataGridCheckBoxColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- ═══ Footer (matches TablePreviewCard pagination footer style) ═══ -->
            <Border Grid.Row="3" Background="#2D2D30" Padding="10,8"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status label -->
                    <TextBlock x:Name="StatusLabel" Grid.Column="0" Text="" FontSize="10" 
                               Foreground="{StaticResource MutedBrush}" 
                               FontFamily="Consolas" VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Style="{StaticResource CardActionBtn}" Click="CloseCard_Click" Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal" Margin="2,0">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Cancel" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource CardPrimaryBtn}" Click="CreateTable_Click">
                            <StackPanel Orientation="Horizontal" Margin="2,0">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Create Table" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
