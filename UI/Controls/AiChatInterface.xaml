<UserControl x:Class="sqlSense.UI.Controls.AiChatInterface"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="300">
    <Grid Background="Transparent">
        
        <!-- Floating AI Button (collapsed state) -->
        <Button x:Name="FloatingAIButton"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Width="48" Height="48"
                Background="{StaticResource PrimaryAccentBrush}"
                Foreground="Black"
                BorderThickness="0"
                Cursor="Hand"
                Effect="{StaticResource NodeShadow}"
                Click="FloatingAIButton_Click"
                Visibility="Collapsed"
                ToolTip="Open AI Assistant">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="24">
                        <TextBlock Text="&#xE90A;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bg" Property="Opacity" Value="0.8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <!-- Chat UI (expanded state) -->
        <Grid x:Name="ChatUI" Background="Transparent" Visibility="Visible">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Hide/Eye Button -->
            <Button Grid.Row="0" 
                    HorizontalAlignment="Right" 
                    Background="Transparent" 
                    BorderThickness="0" 
                    Foreground="{StaticResource TextSecondaryBrush}" 
                    Cursor="Hand" 
                    Click="CloseButton_Click" 
                    ToolTip="Hide Chat"
                    Margin="0,0,0,5">
                <TextBlock Text="&#xE890;" FontFamily="Segoe MDL2 Assets" FontSize="14"/>
            </Button>
            
            <!-- Chat Area -->
            <ScrollViewer x:Name="ChatScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0">
                <StackPanel x:Name="ChatMessagesPanel" Margin="0,0,0,5">
                    <!-- Initial Greeting -->
                    <Border Background="{StaticResource PanelBrush}" Effect="{StaticResource NodeShadow}" CornerRadius="8,8,8,0" Padding="12,10" Margin="0,0,30,10" HorizontalAlignment="Left">
                        <TextBlock Text="Hello! I'm your SQLSense AI Assistant. I can help generate queries, explain data, and optimize your database." 
                                   TextWrapping="Wrap" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Input Area -->
            <Grid Grid.Row="2" Margin="0,5,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="InputTextBox" 
                         Grid.Column="0" 
                         Background="{StaticResource BackgroundBrush}" 
                         Foreground="{StaticResource TextPrimaryBrush}" 
                         BorderBrush="{StaticResource BorderBrush}" 
                         BorderThickness="1" 
                         Padding="10,8,10,8" 
                         TextWrapping="Wrap" 
                         MinHeight="36" 
                         MaxHeight="100" 
                         FontSize="12"
                         VerticalScrollBarVisibility="Auto"
                         AcceptsReturn="True"
                         KeyDown="InputTextBox_KeyDown">
                    <TextBox.Resources>
                        <Style TargetType="{x:Type TextBox}">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="{x:Type TextBox}">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="18" Effect="{StaticResource NodeShadow}">
                                            <Grid>
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="0,4"/>
                                                <TextBlock x:Name="Watermark" Text="Ask AI to write SQL..." Foreground="{StaticResource MutedBrush}" Margin="12,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False" Visibility="Collapsed"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding Text.Length, RelativeSource={RelativeSource Self}}" Value="0">
                                                <Setter TargetName="Watermark" Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                
                <Button Grid.Column="1" 
                        Background="{StaticResource PrimaryAccentBrush}" 
                        Foreground="Black" 
                        BorderThickness="0" 
                        Width="36" 
                        Height="36" 
                        Margin="8,0,0,0" 
                        Cursor="Hand"
                        Effect="{StaticResource NodeShadow}"
                        Click="SendButton_Click" VerticalAlignment="Bottom">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="18">
                                <TextBlock Text="&#xE724;" FontFamily="Segoe MDL2 Assets" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Opacity" Value="0.8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
