<UserControl x:Class="sqlSense.UI.ObjectExplorerPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="280">
    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Panel Header -->
            <Border Background="#2D2D30" Padding="12,8" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                               Foreground="#4FC3F7" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Object Explorer" FontWeight="SemiBold" Foreground="#CCCCCC" 
                               FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Tree View -->
            <TreeView x:Name="ObjectExplorer" Grid.Row="1" 
          Background="Transparent" BorderThickness="0" 
          Foreground="{StaticResource TextSecondaryBrush}" 
          Margin="0" Padding="4"
          ItemsSource="{Binding Explorer.TreeItems}"
          TreeViewItem.Expanded="TreeViewItem_Expanded"
          TreeViewItem.RequestBringIntoView="TreeViewItem_RequestBringIntoView"
          SelectedItemChanged="ObjectExplorer_SelectedItemChanged"
          VirtualizingStackPanel.IsVirtualizing="True"
          VirtualizingStackPanel.VirtualizationMode="Recycling"
          ScrollViewer.HorizontalScrollBarVisibility="Auto"
          ScrollViewer.VerticalScrollBarVisibility="Auto"/>
        </Grid>
    </Border>
</UserControl>
