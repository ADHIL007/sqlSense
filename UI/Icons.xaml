<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Close (X) Icon -->
    <ControlTemplate x:Key="CloseIcon" TargetType="Control">
        <Viewbox Stretch="Uniform">
            <Canvas Width="24" Height="24">
                <Path Data="M 7,7 L 17,17 M 17,7 L 7,17" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="2.2"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
            </Canvas>
        </Viewbox>
    </ControlTemplate>


    <ControlTemplate x:Key="DataToControlSwitchIcon" TargetType="Control">
        <Viewbox Stretch="Uniform">
            <Canvas Width="24" Height="24">
                <!-- Data: Table grid (left side) -->
                <Rectangle Canvas.Left="1" Canvas.Top="6" Width="8" Height="12" 
                           RadiusX="1" RadiusY="1"
                           Stroke="{TemplateBinding Foreground}" StrokeThickness="1.4" Fill="Transparent"/>
                <Line X1="1" Y1="10" X2="9" Y2="10" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1"/>
                <Line X1="1" Y1="14" X2="9" Y2="14" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1"/>
                <Line X1="5" Y1="6" X2="5" Y2="18" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1"/>

                <!-- Transition arrow -->
                <Path Data="M 10.5,12 H 14 M 12.5,10.5 L 14.5,12 L 12.5,13.5" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1.3"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>

                <!-- Control: Flowchart nodes (right side) -->
                <Ellipse Canvas.Left="18" Canvas.Top="4" Width="3" Height="3" 
                         Fill="{TemplateBinding Foreground}"/>
                <Line X1="19.5" Y1="7" X2="19.5" Y2="9" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1.3"/>
                <Polygon Points="19.5,9 22.5,12 19.5,15 16.5,12" 
                         Stroke="{TemplateBinding Foreground}" StrokeThickness="1.2" Fill="Transparent"/>
                <Line X1="19.5" Y1="15" X2="19.5" Y2="17" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1.3"/>
                <Ellipse Canvas.Left="18" Canvas.Top="17" Width="3" Height="3" 
                         Stroke="{TemplateBinding Foreground}" StrokeThickness="1.3" Fill="Transparent"/>
            </Canvas>
        </Viewbox>
    </ControlTemplate>

    <!-- Control → Data Switch Icon: Flowchart transitioning to table grid -->
    <ControlTemplate x:Key="ControlToDataSwitchIcon" TargetType="Control">
        <Viewbox Stretch="Uniform">
            <Canvas Width="24" Height="24">
                <!-- Control: Flowchart nodes (left side) -->
                <Ellipse Canvas.Left="3" Canvas.Top="4" Width="3" Height="3" 
                         Fill="{TemplateBinding Foreground}"/>
                <Line X1="4.5" Y1="7" X2="4.5" Y2="9" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1.3"/>
                <Polygon Points="4.5,9 7.5,12 4.5,15 1.5,12" 
                         Stroke="{TemplateBinding Foreground}" StrokeThickness="1.2" Fill="Transparent"/>
                <Line X1="4.5" Y1="15" X2="4.5" Y2="17" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1.3"/>
                <Ellipse Canvas.Left="3" Canvas.Top="17" Width="3" Height="3" 
                         Stroke="{TemplateBinding Foreground}" StrokeThickness="1.3" Fill="Transparent"/>

                <!-- Transition arrow -->
                <Path Data="M 10.5,12 H 14 M 12.5,10.5 L 14.5,12 L 12.5,13.5" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1.3"
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>

                <!-- Data: Table grid (right side) -->
                <Rectangle Canvas.Left="15" Canvas.Top="6" Width="8" Height="12" 
                           RadiusX="1" RadiusY="1"
                           Stroke="{TemplateBinding Foreground}" StrokeThickness="1.4" Fill="Transparent"/>
                <Line X1="15" Y1="10" X2="23" Y2="10" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1"/>
                <Line X1="15" Y1="14" X2="23" Y2="14" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1"/>
                <Line X1="19" Y1="6" X2="19" Y2="18" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1"/>
            </Canvas>
        </Viewbox>
    </ControlTemplate>

    <!-- Original simpler version, kept for backward compatibility -->
    <ControlTemplate x:Key="IconModeToggle" TargetType="Control">
        <Viewbox Stretch="Uniform">
            <Canvas Width="24" Height="24">
                <!-- Control Flow Nodes -->
                <Ellipse Canvas.Left="2.5" Canvas.Top="4.5" Width="3" Height="3" 
                         Fill="{TemplateBinding Foreground}"/>
                <Ellipse Canvas.Left="2.5" Canvas.Top="10.5" Width="3" Height="3" 
                         Fill="{TemplateBinding Foreground}"/>
                <Ellipse Canvas.Left="2.5" Canvas.Top="16.5" Width="3" Height="3" 
                         Fill="{TemplateBinding Foreground}"/>

                <Line X1="4" Y1="7.5" X2="4" Y2="10.5" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5"/>
                <Line X1="4" Y1="13.5" X2="4" Y2="16.5" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5"/>

                <!-- Transition Arrow -->
                <Path Data="M 8,12 H 15 M 15,12 L 13,10 M 15,12 L 13,14" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5" 
                      StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>

                <!-- Database Cylinder -->
                <Ellipse Canvas.Left="16" Canvas.Top="6.5" Width="6" Height="3" 
                         Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5"/>
                <Path Data="M 16,8 V 14 C 16,14.8 17.3,15.5 19,15.5 S 22,14.8 22,14 V 8" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5"/>
                <Path Data="M 16,11 C 16,11.8 17.3,12.5 19,12.5 S 22,11.8 22,11" 
                      Stroke="{TemplateBinding Foreground}" StrokeThickness="1.5"/>
            </Canvas>
        </Viewbox>
    </ControlTemplate>

</ResourceDictionary>