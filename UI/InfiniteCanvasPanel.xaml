<UserControl x:Class="sqlSense.UI.InfiniteCanvasPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">
    <Border Background="#1E1E1E" ClipToBounds="True">
        <Grid>
            <!-- Canvas Container (handles pan/zoom) -->
            <Border x:Name="CanvasContainer" Background="{StaticResource DotPatternBrush}"
                    ClipToBounds="True"
                    MouseWheel="Canvas_MouseWheel"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    MouseMove="Canvas_MouseMove"
                    MouseRightButtonDown="Canvas_MouseRightButtonDown"
                    MouseRightButtonUp="Canvas_MouseRightButtonUp">
                
                <!-- The actual infinite canvas surface -->
                <Canvas x:Name="FlowCanvas" Width="10000" Height="10000"
                        Background="Transparent"
                        RenderTransformOrigin="0,0">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="CanvasScale" 
                                            ScaleX="{Binding CanvasZoom}" 
                                            ScaleY="{Binding CanvasZoom}"/>
                            <TranslateTransform x:Name="CanvasTranslate" X="0" Y="0"/>
                        </TransformGroup>
                    </Canvas.RenderTransform>

                    <!-- Center cross-hair origin marker -->
                    <Line X1="4990" Y1="5000" X2="5010" Y2="5000" 
                          Stroke="#333333" StrokeThickness="1"/>
                    <Line X1="5000" Y1="4990" X2="5000" Y2="5010" 
                          Stroke="#333333" StrokeThickness="1"/>

                    <!-- Table Data Card (placed on canvas) -->
                    <Border x:Name="TableDataCard" Canvas.Left="4900" Canvas.Top="4950"
                            Background="#252526" BorderBrush="#4FC3F7" BorderThickness="1"
                            CornerRadius="6" MinWidth="300"
                            Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVis}}">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" BlurRadius="16" Opacity="0.5" ShadowDepth="4"/>
                        </Border.Effect>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Card Header -->
                            <Border Background="#4FC3F7" Padding="12,8" CornerRadius="5,5,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE80A;" FontFamily="Segoe MDL2 Assets" FontSize="14" 
                                               Foreground="#1E1E1E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding PreviewTableName}" FontSize="13" 
                                               Foreground="#1E1E1E" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Text=" — TOP 10" FontSize="10" 
                                               Foreground="#1E1E1EAA" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- DataGrid -->
                            <DataGrid Grid.Row="1" Style="{StaticResource DarkDataGrid}"
                                      ItemsSource="{Binding PagedData}"
                                      MaxHeight="200"/>

                            <!-- Pagination Bar -->
                            <Border Grid.Row="2" Background="#2D2D30" Padding="8,6"
                                    CornerRadius="0,0,5,5"
                                    BorderBrush="#3C3C3C" BorderThickness="0,1,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="◀" Style="{StaticResource PaginationButton}" 
                                            Command="{Binding PreviousPageCommand}" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding PageInfo}" FontSize="10" 
                                               Foreground="#888888" VerticalAlignment="Center" Margin="4,0"/>
                                    <Button Content="▶" Style="{StaticResource PaginationButton}" 
                                            Command="{Binding NextPageCommand}" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Canvas>
            </Border>

            <!-- Central Toolbar (bottom center, overlaid) -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Margin="0,0,0,24">
                
                <!-- Data Flow Toggle -->
                <Border Background="#252526" CornerRadius="8" 
                        BorderBrush="#3C3C3C" BorderThickness="1"
                        Margin="0,0,16,0">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="12" Opacity="0.5" ShadowDepth="4"/>
                    </Border.Effect>
                    <Button x:Name="DataFlowToggleBtn" 
                            Content="&#xE14F; DATA FLOW: OFF" FontSize="13" 
                            FontFamily="Segoe MDL2 Assets, Segoe UI"
                            FontWeight="Bold" Foreground="#FF9800"
                            Background="Transparent" BorderThickness="0"
                            Padding="20,12" Cursor="Hand"
                            Click="DataFlowToggleBtn_Click"/>
                </Border>

                <!-- Sync to DB -->
                <Border Background="#252526" CornerRadius="8" 
                        BorderBrush="#3C3C3C" BorderThickness="1"
                        Margin="0,0,16,0">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="12" Opacity="0.5" ShadowDepth="4"/>
                    </Border.Effect>
                    <Button x:Name="GenSqlBtn" 
                            Content="&#xE943; GENERATE SQL" FontSize="13"
                            FontFamily="Segoe MDL2 Assets, Segoe UI"
                            FontWeight="Bold" Foreground="#4FC3F7"
                            Background="Transparent" BorderThickness="0"
                            Padding="20,12" Cursor="Hand"
                            Command="{Binding GenerateViewSqlCommand}"/>
                </Border>

                <!-- Sync to DB -->
                <Border Background="#252526" CornerRadius="8" 
                        BorderBrush="#3C3C3C" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="12" Opacity="0.5" ShadowDepth="4"/>
                    </Border.Effect>
                    <Button x:Name="SyncDbBtn" 
                            Content="&#xE105; SYNC TO DATABASE" FontSize="13"
                            FontFamily="Segoe MDL2 Assets, Segoe UI"
                            FontWeight="Bold" Foreground="#4CAF50"
                            Background="Transparent" BorderThickness="0"
                            Padding="20,12" Cursor="Hand"
                            Command="{Binding SaveViewChangesCommand}"/>
                </Border>
            </StackPanel>

            <!-- Zoom Controls (bottom right, overlaid) -->
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,16,16">
                <Border Background="#252526" CornerRadius="6" 
                        BorderBrush="#3C3C3C" BorderThickness="1"
                        Padding="4">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" Opacity="0.4" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="−" Style="{StaticResource ZoomButton}" 
                                Command="{Binding ZoomOutCommand}" 
                                FontSize="18" FontWeight="Bold"/>
                        <Border Background="#1E1E1E" CornerRadius="3" Padding="8,4" Margin="2,0"
                                VerticalAlignment="Center" MinWidth="50">
                            <TextBlock Text="{Binding ZoomPercentage}" 
                                       Foreground="#CCCCCC" FontSize="11"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontFamily="Consolas"/>
                        </Border>
                        <Button Content="+" Style="{StaticResource ZoomButton}" 
                                Command="{Binding ZoomInCommand}"
                                FontSize="16" FontWeight="Bold"/>
                        <Rectangle Width="1" Fill="#3C3C3C" Margin="4,4"/>
                        <Button Content="⟳" Style="{StaticResource ZoomButton}" 
                                Command="{Binding ZoomResetCommand}"
                                ToolTip="Reset to 100%" FontSize="14"/>
                        <Button Content="⤢" Style="{StaticResource ZoomButton}" 
                                Command="{Binding ZoomFitCommand}"
                                ToolTip="Zoom to fit" FontSize="14"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Canvas coordinate info (bottom left) -->
            <Border Background="#252526EE" CornerRadius="4" Padding="8,4"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Margin="16,0,0,16" BorderBrush="#3C3C3C" BorderThickness="1">
                <TextBlock x:Name="CoordinateLabel" Text="0, 0" 
                           Foreground="#888888" FontSize="10" FontFamily="Consolas"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
