<UserControl x:Class="sqlSense.UI.InfiniteCanvasPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Toolbar Button -->
        <Style x:Key="ToolbarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2D2E"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#094771"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Primary Action Button -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#1A8AD4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small Icon Button -->
        <Style x:Key="SmallIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2D2E"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid for Table Card -->
        <Style x:Key="CardDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowBackground" Value="#252526"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D30"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="IsReadOnly" Value="True"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource BackgroundBrush}" ClipToBounds="True">
        <Grid>
            <!-- Canvas Container -->
            <Border x:Name="CanvasContainer" 
                    Background="{StaticResource DotPatternBrush}"
                    ClipToBounds="True"
                    MouseWheel="Canvas_MouseWheel"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    MouseMove="Canvas_MouseMove"
                    MouseRightButtonDown="Canvas_MouseRightButtonDown"
                    MouseRightButtonUp="Canvas_MouseRightButtonUp">

                <Canvas x:Name="FlowCanvas" Width="10000" Height="10000"
                        Background="Transparent"
                        RenderTransformOrigin="0,0">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="CanvasScale" 
                                            ScaleX="{Binding CanvasZoom}" 
                                            ScaleY="{Binding CanvasZoom}"/>
                            <TranslateTransform x:Name="CanvasTranslate" X="0" Y="0"/>
                        </TransformGroup>
                    </Canvas.RenderTransform>

                    <!-- Origin Crosshair -->
                    <Line X1="4985" Y1="5000" X2="5015" Y2="5000" 
                          Stroke="#3C3C3C" StrokeThickness="1" Opacity="0.4"/>
                    <Line X1="5000" Y1="4985" X2="5000" Y2="5015" 
                          Stroke="#3C3C3C" StrokeThickness="1" Opacity="0.4"/>
                    <Ellipse Width="6" Height="6" Fill="#4FC3F7" 
                             Canvas.Left="4997" Canvas.Top="4997" Opacity="0.6"/>

                    <!-- Table Data Card -->
                    <Border x:Name="TableDataCard" Canvas.Left="4900" Canvas.Top="4950"
                            Background="{StaticResource PanelBrush}" 
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            MinWidth="320"
                            Visibility="{Binding IsPreviewVisible, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Card Header -->
                            <Border Background="#2D2D30" Padding="12,8"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" Grid.Column="0">
                                        <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="13" 
                                                   Foreground="#4FC3F7" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding PreviewTableName}" FontSize="12" 
                                                   Foreground="{StaticResource TextPrimaryBrush}" 
                                                   VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="1" Text="TOP 10" FontSize="9" 
                                               Foreground="{StaticResource MutedBrush}" 
                                               VerticalAlignment="Center" FontFamily="Consolas"/>
                                </Grid>
                            </Border>

                            <!-- DataGrid -->
                            <DataGrid Grid.Row="1" Style="{StaticResource CardDataGrid}"
                                      ItemsSource="{Binding PagedData}"
                                      MaxHeight="250" BorderThickness="0"/>

                            <!-- Pagination -->
                            <Border Grid.Row="2" Background="#2D2D30" Padding="8,6"
                                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="‹" Style="{StaticResource SmallIconBtn}" 
                                            Command="{Binding PreviousPageCommand}" 
                                            FontFamily="Segoe UI" FontSize="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding PageInfo}" FontSize="10" 
                                               Foreground="{StaticResource MutedBrush}" 
                                               FontFamily="Consolas" VerticalAlignment="Center" Margin="4,0"/>
                                    <Button Content="›" Style="{StaticResource SmallIconBtn}" 
                                            Command="{Binding NextPageCommand}" 
                                            FontFamily="Segoe UI" FontSize="16" Margin="6,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Canvas>
            </Border>

            <!-- Floating Toolbar (bottom center) -->
            <Border Background="{StaticResource PanelBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <!-- Data Flow Toggle -->
                    <Button x:Name="DataFlowToggleBtn" 
                            Style="{StaticResource ToolbarBtn}"
                            Click="DataFlowToggleBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{StaticResource WarningBrush}" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Data Flow" FontSize="11.5" FontWeight="Medium"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Border Background="#3C3C3C" CornerRadius="3" Padding="6,2">
                                <TextBlock x:Name="DataFlowState" Text="OFF" FontSize="9" 
                                           Foreground="{StaticResource MutedBrush}" FontWeight="SemiBold"
                                           FontFamily="Consolas"/>
                            </Border>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="0,6"/>

                    <!-- Generate SQL -->
                    <Button x:Name="GenSqlBtn" 
                            Style="{StaticResource ToolbarBtn}"
                            Command="{Binding GenerateViewSqlCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE943;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                       Foreground="{StaticResource PrimaryAccentBrush}" Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="Generate SQL" FontSize="11.5" FontWeight="Medium"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="0,6"/>

                    <!-- Sync to Database -->
                    <Button x:Name="SyncDbBtn" 
                            Style="{StaticResource PrimaryBtn}"
                            Command="{Binding SaveViewChangesCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="13" 
                                       Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Sync to DB" FontSize="11.5" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Zoom Controls (bottom right) -->
            <Border Background="{StaticResource PanelBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,16,16" Padding="2">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource SmallIconBtn}" 
                            Command="{Binding ZoomOutCommand}" ToolTip="Zoom Out">
                        <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>

                    <Border Background="#2D2D30" CornerRadius="3" Padding="8,4" Margin="2,0"
                            MinWidth="48">
                        <TextBlock Text="{Binding ZoomPercentage}" 
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"
                                   HorizontalAlignment="Center" FontFamily="Consolas"/>
                    </Border>

                    <Button Style="{StaticResource SmallIconBtn}" 
                            Command="{Binding ZoomInCommand}" ToolTip="Zoom In">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="4,5"/>

                    <Button Style="{StaticResource SmallIconBtn}" 
                            Command="{Binding ZoomResetCommand}" ToolTip="Reset Zoom">
                        <TextBlock Text="1:1" FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>

                    <Button Style="{StaticResource SmallIconBtn}" 
                            Command="{Binding ZoomFitCommand}" ToolTip="Fit to View">
                        <TextBlock Text="&#xE9A6;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Coordinates (bottom left) -->
            <Border Background="{StaticResource PanelBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="10,5"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Margin="16,0,0,16">
                <TextBlock x:Name="CoordinateLabel" Text="0, 0" 
                           Foreground="{StaticResource MutedBrush}" FontSize="10" 
                           FontFamily="Consolas"/>
            </Border>
        </Grid>
    </Border>
</UserControl>