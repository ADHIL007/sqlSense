<UserControl x:Class="sqlSense.UI.InfiniteCanvasPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:sqlSense.UI.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="800">

    <UserControl.Resources>
        <!-- Small Icon Button -->
        <Style x:Key="SmallIconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A2D2E"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid for Table Card -->
        <Style x:Key="CardDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="RowBackground" Value="#252526"/>
            <Setter Property="AlternatingRowBackground" Value="#2D2D30"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="RowHeight" Value="28"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="SelectionMode" Value="Single"/>
            <Setter Property="SelectionUnit" Value="FullRow"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="ColumnWidth" Value="150"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{StaticResource BackgroundBrush}" ClipToBounds="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ERD Toolbar (left edge) -->
            <controls:CanvasToolbar x:Name="ErdToolbar" Grid.Column="0" 
                                     ShapeRequested="ErdToolbar_ShapeRequested"/>

            <!-- Canvas Container -->
            <Border x:Name="CanvasContainer" Grid.Column="1"
                    Background="{StaticResource DotPatternBrush}"
                    ClipToBounds="True"
                    MouseWheel="Canvas_MouseWheel"
                    MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                    MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                    MouseMove="Canvas_MouseMove"
                    MouseRightButtonDown="Canvas_MouseRightButtonDown"
                    MouseRightButtonUp="Canvas_MouseRightButtonUp">

                <Canvas x:Name="FlowCanvas" Width="10000" Height="10000"
                        Background="Transparent"
                        RenderTransformOrigin="0,0">
                    <Canvas.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="CanvasScale" 
                                            ScaleX="{Binding Canvas.Zoom}" 
                                            ScaleY="{Binding Canvas.Zoom}"/>
                            <TranslateTransform x:Name="CanvasTranslate" X="0" Y="0"/>
                        </TransformGroup>
                    </Canvas.RenderTransform>

                    <!-- Origin Crosshair -->
                    <Line X1="4985" Y1="5000" X2="5015" Y2="5000" 
                          Stroke="#3C3C3C" StrokeThickness="1" Opacity="0.4"/>
                    <Line X1="5000" Y1="4985" X2="5000" Y2="5015" 
                          Stroke="#3C3C3C" StrokeThickness="1" Opacity="0.4"/>
                    <Ellipse Width="6" Height="6" Fill="#4FC3F7" 
                             Canvas.Left="4997" Canvas.Top="4997" Opacity="0.6"/>


                </Canvas>
            </Border>

            <!-- Zoom Controls (bottom right) -->
            <Border Grid.Column="1"
                    Background="{StaticResource PanelBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,16,16" Padding="2">
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource SmallIconBtn}" 
                            Command="{Binding Canvas.ZoomOutCommand}" ToolTip="Zoom Out">
                        <TextBlock Text="&#xE738;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>

                    <Border Background="#2D2D30" CornerRadius="3" Padding="8,4" Margin="2,0"
                            MinWidth="48">
                        <TextBlock Text="{Binding Canvas.ZoomPercentage}" 
                                   Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"
                                   HorizontalAlignment="Center" FontFamily="Consolas"/>
                    </Border>

                    <Button Style="{StaticResource SmallIconBtn}" 
                            Command="{Binding Canvas.ZoomInCommand}" ToolTip="Zoom In">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>

                    <Rectangle Width="1" Fill="{StaticResource BorderBrush}" Margin="4,5"/>

                    <Button Style="{StaticResource SmallIconBtn}" 
                            Command="{Binding Canvas.ZoomResetCommand}" ToolTip="Reset Zoom">
                        <TextBlock Text="1:1" FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Button>

                    <Button Style="{StaticResource SmallIconBtn}" 
                            Command="{Binding Canvas.ZoomFitCommand}" ToolTip="Fit to View">
                        <TextBlock Text="&#xE9A6;" FontFamily="Segoe MDL2 Assets" FontSize="12"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Coordinates (bottom left of canvas area) -->
            <Border Grid.Column="1"
                    Background="{StaticResource PanelBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="4" Padding="10,5"
                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                    Margin="16,0,0,16">
                <TextBlock x:Name="CoordinateLabel" Text="0, 0" 
                           Foreground="{StaticResource MutedBrush}" FontSize="10" 
                           FontFamily="Consolas"/>
            </Border>
        </Grid>
    </Border>
</UserControl>
