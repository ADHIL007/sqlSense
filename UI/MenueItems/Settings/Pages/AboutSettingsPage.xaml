<UserControl x:Class="sqlSense.UI.MenueItems.Settings.Pages.AboutSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../SettingsResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <StackPanel Margin="0,0,0,0">
        <TextBlock Text="About SQLSense" Style="{StaticResource SectionHeader}"/>
        <TextBlock FontSize="28" FontWeight="Bold" Margin="0,0,0,12">
            <Run Text="Sql" Foreground="#1E6FA8"/><Run Text="Sense" Foreground="#F57C00"/>
        </TextBlock>
        <TextBlock Text="Version 1.0.0" Foreground="#CCCCCC" FontSize="12" Margin="0,0,0,6"/>
        <TextBlock Text="A modern SQL Server management and visual query builder." 
                   Foreground="#888888" FontSize="12" Margin="0,0,0,20" TextWrapping="Wrap"/>
        <Rectangle Height="1" Fill="#3C3C3C" Margin="0,0,0,20"/>
        <TextBlock Text="© 2026 SQLSense. All rights reserved." 
                   Foreground="#666666" FontSize="11"/>
    </StackPanel>
</UserControl>
