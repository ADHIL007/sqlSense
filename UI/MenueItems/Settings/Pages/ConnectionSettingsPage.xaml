<UserControl x:Class="sqlSense.UI.MenueItems.Settings.Pages.ConnectionSettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../SettingsResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <StackPanel Margin="0,0,0,0">
        <TextBlock Text="Connection" Style="{StaticResource SectionHeader}"/>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Connection timeout (s):" Style="{StaticResource SettingLabel}"/>
            <TextBox Grid.Column="1" Text="30" Style="{StaticResource SettingTextBox}"/>
        </Grid>

        <Grid Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Command timeout (s):" Style="{StaticResource SettingLabel}"/>
            <TextBox Grid.Column="1" Text="60" Style="{StaticResource SettingTextBox}"/>
        </Grid>

        <Border Height="1" Background="#3C3C3C" Margin="0,8,0,24"/>

        <StackPanel Margin="0,0,0,18">
            <CheckBox Content="Encrypt connection" 
                      Style="{StaticResource SettingCheckBox}" IsChecked="True"/>
            <TextBlock Text="Use encrypted connections to SQL Server." 
                       Style="{StaticResource SettingDescription}" Margin="24,4,0,0"/>
        </StackPanel>

        <StackPanel Margin="0,0,0,18">
            <CheckBox Content="Trust server certificate" 
                      Style="{StaticResource SettingCheckBox}"/>
        </StackPanel>
    </StackPanel>
</UserControl>
