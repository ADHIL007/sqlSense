<Window x:Class="sqlSense.Views.CreateTableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create New Table" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Create New Table" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <StackPanel Margin="0,0,20,0">
                <TextBlock Text="Table Name" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                <TextBox x:Name="TableNameTxt" Width="200" Padding="5" Background="#252526" Foreground="White" BorderBrush="{StaticResource BorderBrush}"/>
            </StackPanel>
            <StackPanel>
                <TextBlock Text="Schema" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,5"/>
                <TextBox x:Name="SchemaNameTxt" Text="dbo" Width="100" Padding="5" Background="#252526" Foreground="White" BorderBrush="{StaticResource BorderBrush}"/>
            </StackPanel>
        </StackPanel>

        <GroupBox Grid.Row="2" Header="Columns" Foreground="{StaticResource TextSecondaryBrush}" BorderBrush="{StaticResource BorderBrush}">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="ColumnsGrid" Grid.Row="0" CanUserAddRows="True" AutoGenerateColumns="False" 
                          Background="Transparent" RowBackground="#2D2D30" BorderThickness="0"
                          VerticalGridLinesBrush="#333" HorizontalGridLinesBrush="#333">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Column Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridComboBoxColumn x:Name="TypeCol" Header="Data Type" Width="120"/>
                        <DataGridTextColumn Header="Length" Binding="{Binding Length}" Width="60"/>
                        <DataGridCheckBoxColumn Header="Nullable" Binding="{Binding IsNullable}" Width="60"/>
                        <DataGridCheckBoxColumn Header="PK" Binding="{Binding IsPrimaryKey}" Width="40"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Add Column" Click="AddColumn_Click" Padding="10,5" Margin="0,0,10,0" Background="#3E3E42" BorderThickness="0"/>
                    <Button Content="Remove Selected" Click="RemoveColumn_Click" Padding="10,5" Background="#3E3E42" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel" IsCancel="True" Padding="20,8" Margin="0,0,10,0" Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}" BorderThickness="0"/>
            <Button Content="Create Table" Click="CreateTable_Click" Padding="25,8" Background="{StaticResource PrimaryAccentBrush}" Foreground="White" BorderThickness="0" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
