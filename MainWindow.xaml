<Window x:Class="sqlSense.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:sqlSense"
        xmlns:models="clr-namespace:sqlSense.Models"
        xmlns:converters="clr-namespace:sqlSense.Converters"
        xmlns:ui="clr-namespace:sqlSense.UI"
        xmlns:controls="clr-namespace:sqlSense.UI.Controls"
        xmlns:ai="clr-namespace:sqlSense.UI.Controls.Ai"
        xmlns:db="clr-namespace:sqlSense.UI.Controls.Database"
        xmlns:sql="clr-namespace:sqlSense.UI.Controls.Sql"
        xmlns:cvs="clr-namespace:sqlSense.UI.Controls.Canvas"
        mc:Ignorable="d"
        Title="{Binding ActiveWorkbook.ViewName, StringFormat='sqlSense - {0}', TargetNullValue='sqlSense'}"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow">

    <Window.InputBindings>
        <!-- F5 = Execute Query (global, like SSMS) -->
        <KeyBinding Key="F5" Command="{Binding RunQueryCommand}"/>
        <!-- Ctrl+E = Execute Query (alternate shortcut) -->
        <KeyBinding Key="E" Modifiers="Control" Command="{Binding RunQueryCommand}"/>
        <!-- Ctrl+S = Save Workbook -->
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveWorkbookCommand}"/>
    </Window.InputBindings>
    
    <Window.Style>
        <Style TargetType="Window">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasUnsavedChanges}" Value="True">
                    <Setter Property="Title" Value="{Binding ActiveWorkbook.ViewName, StringFormat='sqlSense - {0} *'}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Style>

    <Window.Resources>
        <!-- ═══ Segmented Tab Button Style ═══ -->
        <Style x:Key="SegmentedTabBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}"
                                BorderThickness="1" BorderBrush="Transparent"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#094771"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#0D5D99"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="#2A2D2E"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Status Bar Mode Button Style ═══ -->
        <Style x:Key="StatusModeBtn" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#D0D0D0"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#40FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="bd" Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.3"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- Top Menu Bar -->
        <ui:TopMenuBar Grid.Row="0" />

        <!-- ═══ Main Content Area ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- Object Explorer -->
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="280"/>
                            <Setter Property="MinWidth" Value="180"/>
                            <Setter Property="MaxWidth" Value="450"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SqlEditor.IsMaximized}" Value="True">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <!-- Working Area (tabs + toolbar + canvas/editor) -->
                <ColumnDefinition Width="*"/>
                <!-- AI Chat Panel -->
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="320"/>
                            <Setter Property="MinWidth" Value="250"/>
                            <Setter Property="MaxWidth" Value="500"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsAiChatVisible}" Value="False">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SqlEditor.IsMaximized}" Value="True">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Object Explorer -->
            <db:ObjectExplorerPanel x:Name="ObjectExplorerPanel" Grid.Column="0" 
                                    ItemExpanded="TreeViewItem_Expanded"
                                    SelectedItemChanged="ObjectExplorer_SelectedItemChanged" />

            <!-- RIGHT: Tabs + Mode Toolbar + Content (Canvas / Editor) -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="35"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ═══ Workbook Tabs ═══ -->
                <ListBox Grid.Row="0" 
                         ItemsSource="{Binding OpenWorkbooks}"
                         SelectedItem="{Binding ActiveWorkbook}"
                         Background="#1E1E1E" 
                         BorderThickness="0,0,0,1"
                         BorderBrush="#252526"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="#2D2D2D"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="BorderThickness" Value="0,0,1,0"/>
                            <Setter Property="BorderBrush" Value="#252526"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="bd" Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                MinWidth="120" MaxWidth="200">
                                            <Grid Margin="12,0,8,0" Height="35">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="&#xE8B3;" FontFamily="Segoe MDL2 Assets" 
                                                               FontSize="10" VerticalAlignment="Center" Margin="0,0,8,0"
                                                               Foreground="{StaticResource PrimaryAccentBrush}"/>
                                                    <TextBlock Text="{Binding ViewName}" 
                                                               Foreground="{StaticResource TextSecondaryBrush}" 
                                                               FontSize="11" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>

                                                <Button Grid.Column="1"
                                                        x:Name="closeBtn"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0,0,0"
                                                        Cursor="Hand"
                                                        ToolTip="Close"
                                                        Command="{Binding DataContext.CloseWorkbookCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <Control Template="{StaticResource CloseIcon}" Width="10" Height="10"
                                                             Foreground="{StaticResource MutedBrush}"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#1E1E1E"/>
                                                <Setter TargetName="bd" Property="BorderThickness" Value="0,2,1,0"/>
                                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource PrimaryAccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- ═══ Content Area: Canvas + SQL Editor (side by side) ═══ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <!-- Canvas Column -->
                        <ColumnDefinition>
                            <ColumnDefinition.Style>
                                <Style TargetType="ColumnDefinition">
                                    <Setter Property="Width" Value="*"/>
                                    <Style.Triggers>
                                        <!-- In Code-only mode: hide canvas -->
                                        <DataTrigger Binding="{Binding SqlEditor.IsCodeMode}" Value="True">
                                            <Setter Property="Width" Value="0"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ColumnDefinition.Style>
                        </ColumnDefinition>
                        <!-- Editor Column -->
                        <ColumnDefinition>
                            <ColumnDefinition.Style>
                                <Style TargetType="ColumnDefinition">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                    <Style.Triggers>
                                        <!-- In Code-only mode: editor fills everything -->
                                        <DataTrigger Binding="{Binding SqlEditor.IsCodeMode}" Value="True">
                                            <Setter Property="Width" Value="*"/>
                                        </DataTrigger>
                                        <!-- In Split mode: editor gets portion -->
                                        <DataTrigger Binding="{Binding SqlEditor.IsSplitMode}" Value="True">
                                            <Setter Property="Width" Value="*"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ColumnDefinition.Style>
                        </ColumnDefinition>
                    </Grid.ColumnDefinitions>

                    <!-- Canvas Panel -->
                    <ui:InfiniteCanvasPanel x:Name="CanvasPanel" Grid.Column="0">
                        <ui:InfiniteCanvasPanel.Style>
                            <Style TargetType="ui:InfiniteCanvasPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveWorkbook.ViewName}" Value="chat with AI">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ui:InfiniteCanvasPanel.Style>
                    </ui:InfiniteCanvasPanel>

                    <!-- SQL Editor Panel -->
                    <sql:SqlEditorPanel Grid.Column="1">
                        <sql:SqlEditorPanel.Style>
                            <Style TargetType="sql:SqlEditorPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveWorkbook.ViewName}" Value="chat with AI">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </sql:SqlEditorPanel.Style>
                    </sql:SqlEditorPanel>

                    <!-- Center AI Chat Interface -->
                    <ai:AiChatInterface Grid.Column="0" Grid.ColumnSpan="2">
                        <ai:AiChatInterface.Style>
                            <Style TargetType="ai:AiChatInterface">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveWorkbook.ViewName}" Value="chat with AI">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ai:AiChatInterface.Style>
                    </ai:AiChatInterface>

                    <!-- Resizer between canvas and editor (only in Split mode) -->
                    <GridSplitter Grid.Column="0" Width="4" HorizontalAlignment="Right" VerticalAlignment="Stretch" Cursor="SizeWE">
                        <GridSplitter.Template>
                            <ControlTemplate TargetType="GridSplitter">
                                <Border Background="Transparent" Width="4">
                                    <Border Width="1" Background="{StaticResource BorderBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </GridSplitter.Template>
                        <GridSplitter.Style>
                            <Style TargetType="GridSplitter">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SqlEditor.IsSplitMode}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GridSplitter.Style>
                    </GridSplitter>
                </Grid>
            </Grid>

            <!-- OE Resizer -->
            <GridSplitter Grid.Column="0" Width="4" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SqlEditor.IsMaximized}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>

            <!-- RIGHT PANEL: AI Chat -->
            <Border Grid.Column="2" Background="#1E1E1E" BorderThickness="1,0,0,0" BorderBrush="{StaticResource BorderBrush}">
                <ai:AiChatInterface />
            </Border>

            <!-- AI Chat Resizer -->
            <GridSplitter Grid.Column="1" Width="4" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsAiChatVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SqlEditor.IsMaximized}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>
        </Grid>

        <!-- ═══ Bottom Status Bar ═══ -->
        <Border Grid.Row="2" Background="{Binding StatusBackground}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Server Info (left) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding ServerName}" Foreground="White" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Text=" | Connected" Foreground="#E0E0E0" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Status Message -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Separator Width="1" Background="#40FFFFFF" Margin="10,4"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="5,0"/>
                </StackPanel>

                <!-- Right side: Cursor info + Language + Mode Buttons -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                    
                    <!-- Code Info (Hidden in Chart Mode) -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SqlEditor.IsChartMode}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <!-- Cursor position -->
                        <TextBlock Text="{Binding SqlEditor.CursorPosition}" Foreground="#E0E0E0" FontSize="10" 
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>

                        <Separator Width="1" Background="#40FFFFFF" Margin="0,4,12,4"/>

                        <!-- Spaces -->
                        <TextBlock Text="{Binding SqlEditor.SpacesInfo}" Foreground="#E0E0E0" FontSize="10" 
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>

                        <Separator Width="1" Background="#40FFFFFF" Margin="0,4,12,4"/>

                        <!-- Language mode -->
                        <TextBlock Text="{Binding SqlEditor.LanguageMode}" Foreground="#E0E0E0" FontSize="10"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>

                        <Separator Width="1" Background="#40FFFFFF" Margin="0,4,12,4"/>
                    </StackPanel>

                    <!-- Run button -->
                    <Button Command="{Binding RunQueryCommand}" Background="Transparent" 
                            BorderThickness="0" Cursor="Hand" VerticalAlignment="Center"
                            Margin="0,0,16,0" ToolTip="Execute Query (F5)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶" Foreground="{StaticResource SuccessBrush}" FontSize="9" 
                                       VerticalAlignment="Center" Margin="0,0,4,0"/>
                            <TextBlock Text="Run" Foreground="#E0E0E0" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Width="1" Background="#40FFFFFF" Margin="0,4,12,4"/>

                    <!-- View Mode Switcher Buttons -->
                    <Border Background="#20000000" CornerRadius="4" Padding="2" Margin="0,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton GroupName="StatusViewMode"
                                         Style="{StaticResource StatusModeBtn}"
                                         Visibility="Collapsed"
                                         IsChecked="{Binding SqlEditor.IsChartMode, Mode=OneWay}"
                                         Command="{Binding SqlEditor.SetChartModeCommand}"
                                         IsEnabled="{Binding SqlEditor.IsChartDisabled, Converter={StaticResource InverseBool}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Visual" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="StatusViewMode"
                                         Style="{StaticResource StatusModeBtn}"
                                         IsChecked="{Binding SqlEditor.IsCodeMode, Mode=OneWay}"
                                         Command="{Binding SqlEditor.SetCodeModeCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&lt;/&gt;" FontFamily="Consolas" FontSize="9" FontWeight="Bold"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Code" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton GroupName="StatusViewMode"
                                         Style="{StaticResource StatusModeBtn}"
                                         Visibility="Collapsed"
                                         IsChecked="{Binding SqlEditor.IsSplitMode, Mode=OneWay}"
                                         Command="{Binding SqlEditor.SetSplitModeCommand}"
                                         IsEnabled="{Binding SqlEditor.IsChartDisabled, Converter={StaticResource InverseBool}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8A9;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Split" FontSize="10" VerticalAlignment="Center"/>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
