<Window x:Class="sqlSense.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:sqlSense"
        xmlns:models="clr-namespace:sqlSense.Models"
        xmlns:converters="clr-namespace:sqlSense.Converters"
        xmlns:ui="clr-namespace:sqlSense.UI"
        mc:Ignorable="d"
        Title="sqlSense - Database Visualization" Height="800" Width="1280"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow">

    

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="24"/>
        </Grid.RowDefinitions>

        <!-- Top Menu Bar -->
        <ui:TopMenuBar Grid.Row="0" />

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="280"/>
                            <Setter Property="MinWidth" Value="180"/>
                            <Setter Property="MaxWidth" Value="450"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SqlEditor.IsMaximized}" Value="True">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="*"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SqlEditor.IsMaximized}" Value="True">
                                    <Setter Property="Width" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
                <ColumnDefinition>
                    <ColumnDefinition.Style>
                        <Style TargetType="ColumnDefinition">
                            <Setter Property="Width" Value="300"/>
                            <Setter Property="MinWidth" Value="200"/>
                            <Setter Property="MaxWidth" Value="500"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SqlEditor.IsMaximized}" Value="True">
                                    <Setter Property="Width" Value="*"/>
                                    <Setter Property="MaxWidth" Value="Infinity"/>
                                    <Setter Property="MinWidth" Value="200"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding SqlEditor.IsVisible}" Value="False">
                                    <Setter Property="Width" Value="0"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ColumnDefinition.Style>
                </ColumnDefinition>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Object Explorer -->
            <ui:ObjectExplorerPanel x:Name="ObjectExplorerPanel" Grid.Column="0" 
                                    ItemExpanded="TreeViewItem_Expanded"
                                    SelectedItemChanged="ObjectExplorer_SelectedItemChanged" />

            <!-- CENTER PANEL: Infinite Canvas -->
            <ui:InfiniteCanvasPanel x:Name="CanvasPanel" Grid.Column="1" />

            <!-- RIGHT PANEL: SQL Editor -->
            <ui:SqlEditorPanel Grid.Column="2" />

            <!-- Resizers -->
            <GridSplitter Grid.Column="0" Width="4" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSqlEditorMaximized}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>
            
            <GridSplitter Grid.Column="1" Width="4" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                <GridSplitter.Style>
                    <Style TargetType="GridSplitter">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSqlEditorMaximized}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSqlEditorVisible}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </GridSplitter.Style>
            </GridSplitter>
        </Grid>

        <!-- Bottom Status Bar -->
        <Border Grid.Row="2" Background="#007ACC" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <Grid Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#xE99A;" FontFamily="Segoe MDL2 Assets" FontSize="11" Foreground="White" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding ServerName}" Foreground="White" FontSize="11" VerticalAlignment="Center" FontWeight="SemiBold"/>
                    <TextBlock Text=" | Connected" Foreground="#E0E0E0" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Separator Width="1" Background="#40FFFFFF" Margin="10,4"/>
                    <TextBlock Text="{Binding StatusMessage}" Foreground="White" FontSize="11" VerticalAlignment="Center" Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Global Floating Action Button (+ ADD TABLE) -->
        <Border Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,24,60" CornerRadius="28" Background="#007ACC"
                Width="56" Height="56" Cursor="Hand"
                Effect="{StaticResource NodeShadow}">
            <Button Background="Transparent" BorderThickness="0" Click="GlobalAddTable_Click">
                <Grid>
                    <TextBlock Text="&#xE109;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Button>
        </Border>
    </Grid>
</Window>

