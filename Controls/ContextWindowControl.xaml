<UserControl x:Class="sqlSense.Controls.ContextWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:sqlSense.ViewModels"
             xmlns:converters="clr-namespace:sqlSense.Converters"
             mc:Ignorable="d" 
             Foreground="#E0E0E0"
             Width="320">
    
    <UserControl.DataContext>
        <viewmodels:ContextWindowViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <converters:PercentageToGridLengthConverter x:Key="PercentToGridLen" />
        
        <DrawingBrush x:Key="StripedBrush" Viewport="0,0,10,10" ViewportUnits="Absolute" TileMode="Tile">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="Transparent">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,10,10" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#30007ACC">
                        <GeometryDrawing.Pen>
                            <Pen Brush="#30007ACC" Thickness="2" />
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <LineGeometry StartPoint="0,10" EndPoint="10,0" />
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </UserControl.Resources>

    <Border Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1" CornerRadius="6" Padding="15">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.3" ShadowDepth="4"/>
        </Border.Effect>

        <StackPanel>
            <!-- Header -->
            <TextBlock Text="Context Window" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
            
            <!-- Usage Display -->
            <Grid Margin="0,0,0,8">
                <TextBlock Text="{Binding FormattedTokenUsage}" FontSize="12" Foreground="#CCCCCC"/>
                <TextBlock Text="{Binding FormattedPercentage}" FontSize="12" Foreground="#CCCCCC" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Progress Bar -->
            <Grid Height="6" Margin="0,0,0,10">
                <Border Background="#2D2D2D" CornerRadius="3" />
                <Grid ClipToBounds="True">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{Binding Stats.PercentageUsed, Converter={StaticResource PercentToGridLen}}" />
                        <ColumnDefinition Width="{Binding Stats.ReservedPercentage, Converter={StaticResource PercentToGridLen}}" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Background="{Binding BarColor}" CornerRadius="3,0,0,3" />
                    <Border Grid.Column="1" Background="{StaticResource StripedBrush}" CornerRadius="0,3,3,0" />
                </Grid>
            </Grid>

            <!-- Reserved Indicator -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Rectangle Width="12" Height="6" Fill="{StaticResource StripedBrush}" Margin="0,0,6,0" RadiusX="2" RadiusY="2"/>
                <TextBlock Text="Reserved for response" FontSize="11" Foreground="#999999"/>
            </StackPanel>

            <!-- System Breakdown -->
            <TextBlock Text="System" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8" Foreground="#E0E0E0"/>
            
            <Grid Margin="0,0,0,4">
                <TextBlock Text="System Instructions" FontSize="12" Foreground="#AAAAAA"/>
                <TextBlock Text="{Binding SystemInstructionsPctStr}" FontSize="12" Foreground="#AAAAAA" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,0,0,15">
                <TextBlock Text="Tool Definitions" FontSize="12" Foreground="#AAAAAA"/>
                <TextBlock Text="{Binding ToolDefinitionsPctStr}" FontSize="12" Foreground="#AAAAAA" HorizontalAlignment="Right"/>
            </Grid>

            <!-- User Context Breakdown -->
            <TextBlock Text="User Context" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8" Foreground="#E0E0E0"/>
            
            <Grid Margin="0,0,0,4">
                <TextBlock Text="Summary + Messages" FontSize="12" Foreground="#AAAAAA"/>
                <TextBlock Text="{Binding UserContextPctStr}" FontSize="12" Foreground="#AAAAAA" HorizontalAlignment="Right"/>
            </Grid>
            <Grid Margin="0,0,0,15">
                <TextBlock Text="Tool Usage" FontSize="12" Foreground="#AAAAAA"/>
                <TextBlock Text="{Binding ToolUsagePctStr}" FontSize="12" Foreground="#AAAAAA" HorizontalAlignment="Right"/>
            </Grid>

            <!-- Compact Button -->
            <Button Content="Compact Conversation" 
                    Command="{Binding CompactConversationCommand}"
                    Background="#2D2D2D" 
                    Foreground="#E0E0E0" 
                    BorderBrush="#3E3E3E" 
                    BorderThickness="1" 
                    Padding="10,6" 
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#1D1D1D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</UserControl>
